# @maesn/typescript-sdk SDK Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to version control

# Security Configuration
# The SDK supports loading security credentials from environment variables
# with the prefix: MAESN_
#
# Security environment variables:
MAESN_API_KEY=your_apikey_here
MAESN_ACCOUNT_KEY=your_accountkey_here

# Debug Configuration
# Enable HTTP request/response logging for debugging
MAESN_DEBUG=true
